<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Market Detail</title>
    <link href="/css/nav.css" rel="stylesheet">
    <link href="/css/market-detail.css" rel="stylesheet">
</head>
<body>
<%- include('partials/nav', { currentPath }) %>
<main class="page-container">
<div class="top-actions">
    <button id="themeToggleBtn" type="button" class="theme-toggle-btn btn btn-secondary">Mode clair</button>
</div>

<section class="detail-toolbar">
    <div class="saved-shortcuts">
        <span>Raccourcis:</span>
        <% if (!savedSearches || savedSearches.length === 0) { %>
            <span class="empty-shortcut">Aucun</span>
        <% } %>
        <% if (savedSearches && savedSearches.length > 0) { %>
            <% for (let i = 0; i < savedSearches.length; i++) { %>
                <% const search = savedSearches[i]; %>
                <a class="shortcut-link btn btn-secondary" href="/marketDetail?ids=<%= encodeURIComponent((search.itemIds || []).join(',')) %>"><%= search.name %></a>
            <% } %>
        <% } %>
    </div>
</section>

<section class="loading-panel" id="loadingPanel">
    <div class="loading-text" id="loadingText">Chargement des données du marché...</div>
    <div class="progress-bar">
        <div class="progress-value" id="progressValue"></div>
    </div>
</section>

<section id="detailContent"></section>
</main>

</body>
<script src="/js/market_detail_front.js"></script>
<script src="/js/market_detail_loader.js"></script>
<script src="/js/theme_toggle.js"></script>
<script>
    window.__MARKET_DETAIL_IDS__ = "<%= ids_param %>";
</script>
</html>